rules_version = '2';

// ─────────────────────────────────────────────────────────────
// Yoav Agmon Memorial — Firestore Security Rules
//
// Threat model
//   • Anyone can READ all candles, comments, and stories — this is
//     a public memorial; reads are intentionally open.
//   • CREATE requires a Firebase Auth session (anonymous is fine).
//     This blocks bulk spam from random scripts hitting the public
//     Firebase project ID, and gives App Check a hook later.
//   • UPDATE is forbidden — entries are immutable. Edits = delete + recreate.
//   • DELETE requires the caller to have a doc at /admins/{uid}.
//
// Bootstrapping admins
//   Create the document /admins/{uid} for each admin in the Firebase
//   console (Firestore -> + Start collection -> "admins" -> add doc with
//   the user's UID as the document ID, with whatever payload you want —
//   the existence of the doc is what matters, e.g. { name: "Tzafrir" }).
//
// Field validation
//   Each create has minimal sanity checks: required fields exist, are
//   strings, and are within reasonable size. This is defence-in-depth
//   alongside the client-side escapeHtml() applied at render time.
// ─────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Reusable helpers ──────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isShortString(field, max) {
      return field is string && field.size() > 0 && field.size() <= max;
    }

    function isOptionalShortString(field, max) {
      return field == null || (field is string && field.size() <= max);
    }

    function hasServerTimestamp() {
      return request.resource.data.createdAt == request.time;
    }

    // ── Candles: { name: string<=80, createdAt: serverTimestamp } ──
    match /candles/{candleId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.keys().hasOnly(['name', 'createdAt'])
                    && isShortString(request.resource.data.name, 80)
                    && hasServerTimestamp();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ── Helpers for the moderation flow (P0-7) ─────────────
    // Comments and stories are now gated by a status field:
    //   pending    — submitted by a visitor, not yet visible
    //   approved   — admin reviewed; visible on the public site
    //   rejected   — admin reviewed and chose to hide; kept for audit
    //
    // Backwards compat: docs created before this rule was deployed
    // were backfilled to status='approved' by scripts/migrate-add-status.js,
    // so the public listener's `where status == 'approved'` query catches
    // both pre-existing and newly-approved entries.
    function isModeratedStatus(field) {
      // Admin moderation can move a doc to either approved or rejected.
      // (Returning to 'pending' is intentionally not allowed — moderation
      // is a one-way decision, with delete as the escape hatch.)
      return field == 'approved' || field == 'rejected';
    }
    function isOnlyStatusUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && isModeratedStatus(request.resource.data.status);
    }

    // ── Comments: { name, relation?, text, dateStr?, createdAt, status } ──
    match /comments/{commentId} {
      // Public can read approved entries + the rare unmigrated legacy doc
      // missing the status field. Admins can read everything (pending too)
      // so the moderation queue can subscribe.
      allow read: if isAdmin()
                    || !('status' in resource.data)
                    || resource.data.status == 'approved';
      allow create: if isSignedIn()
                    && request.resource.data.keys().hasOnly(
                         ['name', 'relation', 'text', 'dateStr', 'createdAt', 'status'])
                    && isShortString(request.resource.data.name, 80)
                    && isOptionalShortString(request.resource.data.relation, 80)
                    && isShortString(request.resource.data.text, 2000)
                    && isOptionalShortString(request.resource.data.dateStr, 40)
                    && hasServerTimestamp()
                    && request.resource.data.status == 'pending';
      // Admin moderation: flip status pending→approved or →rejected.
      // Nothing else about the doc may change.
      allow update: if isAdmin() && isOnlyStatusUpdate();
      allow delete: if isAdmin();
    }

    // ── Stories: { author?, text, dateStr?, createdAt, status } ──
    match /stories/{storyId} {
      allow read: if isAdmin()
                    || !('status' in resource.data)
                    || resource.data.status == 'approved';
      allow create: if isSignedIn()
                    && request.resource.data.keys().hasOnly(
                         ['author', 'text', 'dateStr', 'createdAt', 'status'])
                    && isOptionalShortString(request.resource.data.author, 80)
                    && isShortString(request.resource.data.text, 5000)
                    && isOptionalShortString(request.resource.data.dateStr, 40)
                    && hasServerTimestamp()
                    && request.resource.data.status == 'pending';
      allow update: if isAdmin() && isOnlyStatusUpdate();
      allow delete: if isAdmin();
    }

    // ── Places: pinned spots on Yoav's Map (P3-1) ──
    //   { name, story?, photoUrl?, lat, lng, createdAt }
    // Public can view all pins. Only admins can add/edit/delete —
    // no public submissions in this MVP. (Visitor-submitted pins
    // could be added later by mirroring the comments moderation flow.)
    match /places/{placeId} {
      allow read: if true;
      allow create: if isAdmin()
                    && request.resource.data.keys().hasOnly(
                         ['name', 'story', 'photoUrl', 'lat', 'lng', 'createdAt'])
                    && isShortString(request.resource.data.name, 80)
                    && isOptionalShortString(request.resource.data.story, 2000)
                    && isOptionalShortString(request.resource.data.photoUrl, 500)
                    && request.resource.data.lat is number
                    && request.resource.data.lat >= -90
                    && request.resource.data.lat <= 90
                    && request.resource.data.lng is number
                    && request.resource.data.lng >= -180
                    && request.resource.data.lng <= 180
                    && hasServerTimestamp();
      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['name', 'story', 'photoUrl', 'lat', 'lng']);
      allow delete: if isAdmin();
    }

    // ── Letters: Time Capsule (P3-6) ──
    //   { author, text, revealDate (timestamp), createdAt }
    // Letters are sealed — visible only on/after their revealDate.
    // Admins can see all letters at any time so they can manage the
    // queue (counter, deletion, etc.) and verify what they wrote.
    //
    // The public listener uses where('revealDate', '<=', now) which
    // returns only docs whose read rule already passes — visitors
    // never see sealed content even if their browser tries.
    match /letters/{letterId} {
      allow read: if isAdmin()
                    || resource.data.revealDate <= request.time;
      allow create: if isAdmin()
                    && request.resource.data.keys().hasOnly(
                         ['author', 'text', 'revealDate', 'createdAt'])
                    && isShortString(request.resource.data.author, 80)
                    && isShortString(request.resource.data.text, 5000)
                    && request.resource.data.revealDate is timestamp
                    && hasServerTimestamp();
      allow update: if false;     // sealed = sealed; edits = delete + recreate
      allow delete: if isAdmin();
    }

    // ── Songs: Music for Yoav ──
    //   { title, artist, note?, type, platform, embedId, createdAt }
    // Public read so visitors can listen. Admin-only writes — songs are
    // curated by family (no visitor submissions in this iteration).
    //
    // type     ∈ { 'loved', 'about' }
    // platform ∈ { 'youtube', 'spotify' }
    // embedId  is the platform-specific ID we render in the iframe URL.
    //          We store it raw and build the iframe src on the client,
    //          so a hostile embedId cannot escape the URL grammar — the
    //          worst case is a broken iframe.
    function isSongType(v)     { return v == 'loved'   || v == 'about'; }
    function isSongPlatform(v) { return v == 'youtube' || v == 'spotify'; }
    match /songs/{songId} {
      allow read: if true;
      allow create: if isAdmin()
                    && request.resource.data.keys().hasOnly(
                         ['title', 'artist', 'note', 'type', 'platform', 'embedId', 'createdAt'])
                    && isShortString(request.resource.data.title, 200)
                    && isShortString(request.resource.data.artist, 200)
                    && isOptionalShortString(request.resource.data.note, 500)
                    && isSongType(request.resource.data.type)
                    && isSongPlatform(request.resource.data.platform)
                    && isShortString(request.resource.data.embedId, 80)
                    && hasServerTimestamp();
      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['title', 'artist', 'note', 'type', 'platform', 'embedId']);
      allow delete: if isAdmin();
    }

    // ── Admins: read your own doc, never write from the client ──
    // Bootstrap by creating these in the Firebase Console.
    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // ── Default deny ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
